{
  "name": "@cygnet/extension",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-vite-target.mjs dev chrome",
    "dev:chrome": "node ./scripts/run-vite-target.mjs dev chrome",
    "dev:safari": "node ./scripts/run-vite-target.mjs dev safari",
    "build": "node ./scripts/run-vite-target.mjs build chrome",
    "build:chrome": "node ./scripts/run-vite-target.mjs build chrome",
    "build:safari": "node ./scripts/run-vite-target.mjs build safari",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-safari"
  },
  "dependencies": {
    "@cygnet/shared": "workspace:*",
    "@supabase/supabase-js": "^2.99.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@types/chrome": "^0.0.300",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5.7",
    "vite": "^6"
  }
}
