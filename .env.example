# ============================================================
# Website (apps/web/.env.local)
# ============================================================

# Supabase project credentials (Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional fallback for dashboard -> extension login sync
NEXT_PUBLIC_EXTENSION_ID=your-extension-id

# Optional: enables AI-powered resume parsing via GPT-4o-mini
OPENAI_API_KEY=sk-...

# ============================================================
# Chrome Extension (apps/extension/.env)
# ============================================================

# Same Supabase credentials with VITE_ prefix (embedded at build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth Client ID (Cloud Console > APIs & Services > Credentials)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Optional dashboard URL used by the extension "Webダッシュボード" button
VITE_WEB_DASHBOARD_URL=http://localhost:3000/dashboard
